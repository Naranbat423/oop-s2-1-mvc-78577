@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Community Library</h1>
    <p>Manage your library books, members, and loans efficiently.</p>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>Books</h5>
            </div>
            <div class="card-body">
                <p>Manage your book collection - add, edit, delete and search books.</p>
                <a asp-controller="Books" asp-action="Index" class="btn btn-primary">Go to Books</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5>Members</h5>
            </div>
            <div class="card-body">
                <p>Manage library members - register new members and update details.</p>
                <a asp-controller="Members" asp-action="Index" class="btn btn-success">Go to Members</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-warning">
                <h5>Loans</h5>
            </div>
            <div class="card-body">
                <p>Manage book loans - create new loans and track returns.</p>
                <a asp-controller="Loans" asp-action="Index" class="btn btn-warning">Go to Loans</a>
            </div>
        </div>
    </div>
</div>

@if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
{
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5>Admin</h5>
                </div>
                <div class="card-body">
                    <p>Admin-only role management.</p>
                    <a asp-area="Admin" asp-controller="Roles" asp-action="Index" class="btn btn-danger">Role Management</a>
                </div>
            </div>
        </div>
    </div>
}