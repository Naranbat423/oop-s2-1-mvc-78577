@model IEnumerable<Library.Domain.Models.Book>
@using Library.MVC.Models.ViewModels
@{
    ViewData["Title"] = "Books";
    var filterVM = ViewBag.FilterViewModel as BookFilterViewModel;
}

<h1>Books</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Book</a>
</p>

<!-- Search and Filter Form -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label>Search by Title or Author</label>
                <input type="text" name="searchTerm" class="form-control" value="@filterVM?.SearchTerm" placeholder="Search..." />
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label>Category</label>
                <select name="selectedCategory" class="form-control">
                    <option value="">All Categories</option>
                    @foreach (var category in filterVM?.Categories ?? new List<SelectListItem>())
                    {
                        <option value="@category.Value" selected="@category.Selected">@category.Text</option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label>Availability</label>
                <select name="availabilityFilter" class="form-control">
                    @foreach (var option in filterVM?.AvailabilityOptions ?? new List<SelectListItem>())
                    {
                        <option value="@option.Value" selected="@(option.Value == filterVM?.AvailabilityFilter)">@option.Text</option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-action="Index" class="btn btn-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.Isbn</td>
                <td>@item.Category</td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">On Loan</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>